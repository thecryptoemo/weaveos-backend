generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = -1
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  products  Product[]
  reports   Report[]
  storeBrain StoreBrain[]
  logs      AuditLog[]
  tasks     AgentTask[]
  orders    Order[]
  intel     Intelligence[]
}

model Product {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  category     String
  status       String   @default("RESEARCHING")
  winningScore Float?
  marketData   String?  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  suppliers    Supplier[]
}

model Supplier {
  id           String   @id @default(cuid())
  tenantId     String
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  name         String
  source       String
  price        Float?
  moq          Int?
  rating       Float?
  status       String   @default("DISCOVERED")
  negotiations Negotiation[]
  orders       Order[]
}

model Negotiation {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  status      String   @default("ACTIVE")
  history     String   @default("[]")
  createdAt   DateTime @default(now())
}

model Order {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  productName String
  units       Int
  totalAmount Float
  status      String   @default("CONFIRMED")
  eta         String?
  createdAt   DateTime @default(now())
}

model Intelligence {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  title     String
  type      String 
  badge     String? 
  content   String
  timestamp DateTime @default(now())
}

model Report {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  title     String
  content   String
  type      String   @default("RESEARCH")
  createdAt DateTime @default(now())
}

model StoreBrain {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  key      String
  value    String 
  @@unique([tenantId, key])
}

model AuditLog {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  action    String
  entity    String
  timestamp DateTime @default(now())
}

model AgentTask {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  agentName String
  status    String
  progress  Int    @default(0)
  details   String?
  updatedAt DateTime @updatedAt
}